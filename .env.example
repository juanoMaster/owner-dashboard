# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (emails transaccionales)
RESEND_API_KEY=

# Panel admin global (/admin)
ADMIN_TOKEN=

# Autenticación de cron jobs de Vercel
CRON_SECRET=

# URLs públicas de la plataforma
NEXT_PUBLIC_APP_URL=https://panel.takai.cl
NEXT_PUBLIC_RESERVAS_URL=https://reservas.takai.cl

# Twilio — WhatsApp saliente y entrante (/api/twilio/webhook)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Health check (/api/health) — clave opcional para autorizar el endpoint vía header x-health-key o query ?key=
HEALTH_CHECK_KEY=

# Billing — suscripciones de Takai a sus tenants (INDEPENDIENTE del MP Marketplace de turistas)
# Access token de la cuenta propia de Takai en MercadoPago (no del tenant)
MP_PLATFORM_ACCESS_TOKEN=
# Secret HMAC para verificar webhooks de preapproval (se configura en el panel de MP de Takai)
MP_PLATFORM_WEBHOOK_SECRET=

# Datos bancarios de Takai para recibir comisiones por transferencia
# (se muestran en el email de estado de cuenta que recibe el tenant)
TAKAI_BANK_NAME=
TAKAI_BANK_ACCOUNT_TYPE=
TAKAI_BANK_ACCOUNT_NUMBER=
TAKAI_BANK_HOLDER_NAME=
TAKAI_BANK_HOLDER_RUT=
TAKAI_BANK_EMAIL=

# Email del administrador de Takai (alertas internas, acuse de transferencias)
ADMIN_EMAIL=contacto@takai.cl
